root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.php]
indent_style = space
indent_size = 4

[*.{js,json}]
indent_style = space
indent_size = 2

[*.css]
indent_style = space
indent_size = 2

[*.{html,htm}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4

[*.sh]
end_of_line = lf
